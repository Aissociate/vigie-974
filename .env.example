# Copiez ce fichier en .env et renseignez vos valeurs (ne jamais committer .env)

# Stripe — commencez par les clés de TEST (sk_test_…)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# URL publique du site (sert aux redirections Stripe)
SITE_URL=http://localhost:3000

# AgentMail — clé d'envoi (régénérez-la si elle a fui)
AGENTMAIL_API_KEY=am_us_xxx

# Inbox d'envoi — OPTIONNEL (déjà câblée par défaut dans lib/livraison-vigie974.js)
# AGENTMAIL_INBOX_ID=am_us_inbox_xxx

# Chemin du fichier-base — OPTIONNEL (par défaut lib/base-974-complete.csv)
# BASE_CSV_PATH=./lib/base-974-complete.csv

# Supabase — persistance du registre des exclusifs (RECOMMANDÉ en production)
# Si ces deux variables sont définies, le registre des contacts vendus en exclusivité
# est stocké dans la table `exclusifs_vendus` (voir supabase/migrations). Sinon, repli
# automatique sur le fichier JSON ci-dessous (dev local / tests).
# ⚠️ SUPABASE_SERVICE_ROLE_KEY est une clé d'admin : backend uniquement, jamais côté navigateur.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Registre des exclusifs — FICHIER DE SECOURS (utilisé si Supabase non configuré)
# DATA_DIR=./data
# EXCLUSIFS_PATH=./data/exclusifs-vendus.json
